<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="8dp"
    android:background="?attr/colorSurfaceContainerHigh">

    <CheckBox
        android:id="@+id/cbPopupDeleteNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Удаления уведомлений" />

    <CheckBox
        android:id="@+id/cbPopupIgnoreApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Игнора приложений" />

    <CheckBox
        android:id="@+id/cbPopupDeleteImages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Удаления изображений" />
</LinearLayout>