<!-- res/layout/dialog_skip_confirmations.xml -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">
    <TextView
        style="@style/TextAppearance.Material3.TitleMedium"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Не показывать подтверждение для:" />
    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbSkipDeleteNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Удаления уведомлений" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbSkipIgnoreApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Игнора приложений" />

    <com.google.android.material.checkbox.MaterialCheckBox
        android:id="@+id/cbSkipDeleteImages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Удаления изображений" />

</LinearLayout>