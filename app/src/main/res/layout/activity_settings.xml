<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:layout_marginTop="?attr/actionBarSize">

    <Switch
        android:id="@+id/switchDisableDuplicateNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="?attr/actionBarSize"
        android:text="Не сохранять обновления уведомлений" />

    <!-- Лимит уведомлений на приложение -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Макс. уведомлений на приложение" />

        <EditText
            android:id="@+id/etMaxNotificationsPerApp"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="100" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSaveMaxNotificationsPerApp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="Сохранить"
        android:layout_marginTop="4dp" />
    <!-- Лимит по дням -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Макс. дней хранения уведомлений" />

        <EditText
            android:id="@+id/etMaxDays"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="365" />
    </LinearLayout>

    <Button
        android:id="@+id/btnSaveMaxDays"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:text="Сохранить"
        android:layout_marginTop="4dp" />

    <!-- Раздел Статистика -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Статистика"
        android:textSize="18sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Памяти занимают уведомления" />

        <TextView
            android:id="@+id/tvNotificationsMemory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Пока 0" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Памяти занимают изображения" />

        <TextView
            android:id="@+id/tvImagesMemory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Пока 0" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Пришло уведомлений за всё время" />

        <TextView
            android:id="@+id/tvTotalNotifications"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Пока 0" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Пришло уведомлений за последние 24 часа" />

        <TextView
            android:id="@+id/tvNotifications24h"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Пока 0" />
    </LinearLayout>

    <!-- Кнопка отключения подтверждений -->
    <Button
        android:id="@+id/btnSkipConfirmationSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Удалить подтверждение для" />

    <!-- Кнопки удаления -->
    <Button
        android:id="@+id/btnDeleteAllNotifications"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Удалить все уведомления" />

    <Button
        android:id="@+id/btnManageIgnoredApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Управление игнорируемыми приложениями" />

    <Button
        android:id="@+id/btnDeleteAllImages"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Удалить все изображения" />

</LinearLayout>